# Global config for local dev — copy to .env at the repo root.
# The DevOps/Local scripts source this file and export it to every service.
# In cloud (AWS/Azure/GCP) you DON'T ship this file: set CAF_SECRET_PROVIDER to a
# cloud provider and the values below are read from the secret store instead.

# --- Which secret provider the CAF library uses (env | aws | azure | gcp) ---
# Locally: env (reads these vars). Deployed: aws/azure/gcp (reads the secret store).
CAF_SECRET_PROVIDER=env
CAF_SECRET_ENV_ENABLED=true
CAF_SECRET_AWS_ENABLED=false
CAF_SECRET_AZURE_ENABLED=false
CAF_SECRET_GCP_ENABLED=false
# Cloud provider config (only used when that provider is selected):
# CAF_SECRET_AWS_REGION=us-east-1
# CAF_SECRET_AWS_SECRET_NAME=img2pmpt/app           # a JSON bundle of the keys below
# CAF_SECRET_AZURE_VAULT_URL=https://<vault>.vault.azure.net/
# CAF_SECRET_GCP_PROJECT_ID=<project>
# CAF_SECRET_GCP_SECRET_PREFIX=img2pmpt-

# --- Postgres (shared server; one db, schema per service) ---
PG_PORT=5432
POSTGRES_USER=image2prompt
POSTGRES_PASSWORD=image2prompt
POSTGRES_DB=image2prompt
DATABASE_URL=postgresql+psycopg://image2prompt:image2prompt@localhost:5432/image2prompt

# --- Shared auth secret (identical across services) ---
JWT_SECRET=dev-insecure-secret-change-me-please-32b
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_MINUTES=43200

# --- Encryption at rest for stored secrets (e.g. OAuth tokens). Blank = disabled
# (values stored as-is). Set a long random secret in cloud to encrypt them. ---
TOKEN_ENCRYPTION_KEY=
# Previous key(s) for rotation (comma-separated). Decryption falls back to these;
# run the admin re-encrypt action, then remove the old key from here.
TOKEN_ENCRYPTION_KEY_PREVIOUS=

# --- Background housekeeping (periodic prune jobs) ---
SCHEDULER_ENABLED=true
PRUNE_INTERVAL_SECONDS=3600

# --- Account lockout (temporary lock after repeated failed logins; auto-unlocks) ---
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_WINDOW_MINUTES=15

# --- Gateway rate limits ---
RATE_LIMIT_RPM=120
AUTH_RATE_LIMIT_RPM=10
# Window store: "memory" (per-replica) or "redis" (shared across gateway replicas).
# Redis failures degrade gracefully to in-memory.
RATELIMIT_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# --- Outbound email (password reset / verification). Blank host = "not configured":
# flows still succeed but the link is logged instead of sent. ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM=no-reply@image2prompt.io

# --- Inter-service URLs (localhost ports) ---
ADMIN_SERVICE_URL=http://localhost:8001
CUSTOMER_SERVICE_URL=http://localhost:8002
AI_ADAPTERS_URL=http://localhost:8003
IMAGE_SERVICE_URL=http://localhost:8004
GATEWAY_URL=http://localhost:8000

# --- Seed admin ---
ADMIN_EMAIL=admin@image2prompt.io
ADMIN_PASSWORD=admin12345

# --- Observability (OpenTelemetry) ---
# Enabled for local dev so traces/metrics flow to the local OTel stack
# (npm run local:containers:start-all brings up Collector/Jaeger/Prometheus/Grafana).
# Safe to leave on even if the stack isn't running — it degrades to no-op.
OTEL_ENABLED=true
OTEL_SERVICE_NAMESPACE=image2prompt
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_ENABLED=true
OTEL_METRICS_ENABLED=true
OTEL_SPAN_ATTRS_ENABLED=true
OTEL_CONSOLE_FALLBACK=false

# --- AI providers ---
# mock works with none of these. bedrock + the framework providers (strands,
# langgraph, crewai, llamaindex) use AWS creds. The direct-SDK providers need
# their own key below. Leave blank to disable a provider (it returns an error
# envelope if invoked). Locally these are read from env; in cloud they live in
# the CAF secret bundle instead.
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google (Gemini)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash

# Microsoft (Azure OpenAI)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Mistral (Pixtral)
MISTRAL_API_KEY=
MISTRAL_MODEL=pixtral-12b-2409

# Cohere (Aya Vision)
COHERE_API_KEY=
COHERE_MODEL=c4ai-aya-vision-8b

# Ollama (local; no key — OpenAI-compatible endpoint)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llava

# --- LLM routers (img2pmpt-caf-routers) ---
CAF_ROUTERS_OPENROUTER_ENABLED=true
CAF_ROUTERS_LITELLM_ENABLED=true
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LiteLLM routes by model prefix and reuses the underlying provider's key (above).
LITELLM_MODEL=gpt-4o

# --- Billing (Stripe; blank = billing reports "not configured") ---
STRIPE_API_KEY=
STRIPE_CURRENCY=usd

# --- Google Drive OAuth for Connections (blank = "not configured") ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/customer/me/connections/google/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT=http://localhost:4200/connections

# --- OneDrive / Microsoft Graph OAuth for Connections (blank = "not configured") ---
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:8000/api/customer/me/connections/onedrive/callback
MICROSOFT_OAUTH_SCOPES="openid email offline_access Files.Read"
MICROSOFT_OAUTH_SUCCESS_REDIRECT=http://localhost:4200/connections

# --- Customer portal base URL (password-reset / email-verification links land here) ---
PORTAL_BASE_URL=http://localhost:4200

# --- Storage (per-customer preference picks the backend; defaults below) ---
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=/data/uploads
# S3 (uses default AWS creds)
S3_BUCKET=
S3_PREFIX=uploads/
# Azure Blob (connection string OR account URL + default credential)
AZURE_BLOB_CONTAINER=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=
# GCP Cloud Storage (uses Application Default Credentials)
GCS_BUCKET=
GCS_PREFIX=uploads/
