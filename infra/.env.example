# Copy to .env (docker compose reads this automatically).

# --- Shared auth secret (MUST be identical across services) ---
JWT_SECRET=dev-insecure-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Postgres ---
POSTGRES_USER=image2prompt
POSTGRES_PASSWORD=image2prompt
POSTGRES_DB=postgres

# --- Seed admin (created on admin-service startup) ---
ADMIN_EMAIL=admin@image2prompt.io
ADMIN_PASSWORD=admin12345

# --- AI providers (optional; mock provider works with none of these) ---
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
# ANTHROPIC_API_KEY=

# --- Storage ---
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=/data/uploads
